# Copy to .env (git-ignored) for local development. Never commit real secrets.

# REQUIRED: the single shared bearer key clients must present.
YOLO_DETECT_API_KEY=change-me-to-a-strong-shared-secret

# Server bind
YOLO_DETECT_HOST=0.0.0.0
YOLO_DETECT_PORT=8000

# Models
YOLO_DETECT_MODELS_DIR=./models
YOLO_DETECT_DEFAULT_MODEL=yolo26-n
YOLO_DETECT_AVAILABLE_MODELS=yolo26-n,yolo26-s

# Detector defaults
YOLO_DETECT_CONF_THRESHOLD=0.25
YOLO_DETECT_IOU_THRESHOLD=0.45
YOLO_DETECT_INPUT_SIZE=640

# Input safety limits
YOLO_DETECT_MAX_IMAGE_BYTES=10485760
YOLO_DETECT_MAX_IMAGE_PIXELS=25000000
YOLO_DETECT_ALLOWED_FORMATS=jpeg,png,webp
YOLO_DETECT_MAX_IMAGES_PER_REQUEST=8

# Concurrency (avoid oversubscription: pool_size * intra_op_threads ~<= cores)
# YOLO_DETECT_WORKER_POOL_SIZE=
YOLO_DETECT_ORT_INTRA_OP_THREADS=1
YOLO_DETECT_REQUEST_TIMEOUT_S=30

# Logging
YOLO_DETECT_LOG_LEVEL=INFO
